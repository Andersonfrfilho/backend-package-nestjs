{
  "name": "backend-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for backend shared packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "turbo run build",
    "build:packages": "turbo run build --scope packages/**",
    "build:libs-ordered": "pnpm --filter @adatechnology/http-client run build && pnpm --filter @adatechnology/auth-keycloak run build",
    "build:all": "pnpm run build:libs-ordered && pnpm --filter example build || true",
    "dev": "turbo run dev --parallel",
    "clean": "rm -rf dist packages/**/dist",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version:changeset": "changeset version",
    "publish:changesets": "changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 4173",
    "example:start": "pnpm --filter example run start",
    "watch:packages": "pnpm -r --parallel run build:watch"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.16 || ^9",
    "@nestjs/core": "^11 || ^9.0.5"
  },
  "devDependencies": {
    "changesets": "^1.0.2",
    "@changesets/cli": "^2.26.0",
    "@changesets/changelog-github": "^0.6.0",
    "@types/node": "^22.10.7",
    "pnpm": "^8.0.0",
    "tslib": "^2.5.0",
    "turbo": "^1.8.0",
    "vitepress": "^1.6.4",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "rxjs": "^7.8.2"
  }
}