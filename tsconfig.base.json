{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@adatechnology/package-nestjs": ["packages/package-nestjs/src"],
      "@adatechnology/package-nestjs/*": ["packages/package-nestjs/src/*"],
      "@adatechnology/http-client": ["packages/http/src"],
      "@adatechnology/http-client/*": ["packages/http/src/*"],
      "@adatechnology/logger": ["packages/logger/src"],
      "@adatechnology/logger/*": ["packages/logger/src/*"],
      "@adatechnology/auth-keycloak": ["packages/keycloak/src"],
      "@adatechnology/auth-keycloak/*": ["packages/keycloak/src/*"],
      "@adatechnology/shared": ["packages/shared/src"],
      "@adatechnology/shared/*": ["packages/shared/src/*"],
      "@adatechnology/cache": ["packages/cache/src"],
      "@adatechnology/cache/*": ["packages/cache/src/*"],
      "#shared": ["packages/shared/src"],
      "#shared/*": ["packages/shared/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
