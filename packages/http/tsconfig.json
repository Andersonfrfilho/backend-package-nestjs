{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "declarationDir": "dist",
    "declaration": true,
    "composite": true
    ,
    "paths": {
      "@adatechnology/logger": ["../logger/dist", "../logger/dist"],
      "@adatechnology/logger/*": ["../logger/dist/*", "../logger/dist/*"]
    }
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../shared" },
    { "path": "../logger" }
  ]

}
