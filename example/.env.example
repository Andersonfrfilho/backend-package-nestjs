## Example environment for the Keycloak example
# Copy this file to .env and adjust values as needed before running

# Keycloak host port on the host machine (the compose maps this to container 8080)
KEYCLOAK_PORT=9090

# Optional: explicit base URL (defaults to http://localhost:${KEYCLOAK_PORT})
#KEYCLOAK_BASE_URL=http://localhost:9090

# Realm and client created by the example import (see keycloak-config/example-realm.json)
KEYCLOAK_REALM=example
KEYCLOAK_CLIENT_ID=example-client
# public client in the example realm doesn't have a secret
KEYCLOAK_CLIENT_SECRET=

# Grant type the example app will use when calling Keycloak (password or client_credentials)
KEYCLOAK_GRANT_TYPE=password

# API port for the example Nest app
PORT=3000

# Other optional variables
# NODE_ENV=development
